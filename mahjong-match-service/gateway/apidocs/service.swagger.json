{
  "swagger": "2.0",
  "info": {
    "title": "Mahjong Match Service API",
    "version": "v1"
  },
  "tags": [
    {
      "name": "Service"
    }
  ],
  "basePath": "/mahjong",
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/namespaces/{namespace}/jade": {
      "get": {
        "summary": "Get the authenticated player's Jade account",
        "description": "Creates the two idempotent new-player grants when needed and returns authoritative Bamboo eligibility and available balance.",
        "operationId": "Service_GetJadeAccount",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serviceGetJadeAccountResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Service"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/v1/namespaces/{namespace}/jade/reservation": {
      "delete": {
        "summary": "Release an unbound Bamboo Courtyard reservation",
        "description": "Releases the caller's queue reservation. A reservation already bound to a match remains locked until settlement.",
        "operationId": "Service_ReleaseJade",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serviceReleaseJadeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Service"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      },
      "post": {
        "summary": "Reserve the Bamboo Courtyard debit cap",
        "description": "Atomically checks eligibility and locks 300 Jade before the player creates a public matchmaking ticket.",
        "operationId": "Service_ReserveJade",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serviceReserveJadeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ServiceReserveJadeBody"
            }
          }
        ],
        "tags": [
          "Service"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/v1/namespaces/{namespace}/sessions/{sessionId}/matches/{matchId}": {
      "get": {
        "summary": "Get the authenticated player's match state",
        "description": "Returns the latest authoritative match projection visible to the authenticated Session member.",
        "operationId": "Service_GetMatchState",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serviceGetMatchStateResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Service"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/v1/namespaces/{namespace}/sessions/{sessionId}/matches/{matchId}/commands": {
      "post": {
        "summary": "Submit an authoritative Mahjong command",
        "description": "Durably applies an idempotent draw, discard, or claim command and returns the authenticated player's updated projection.",
        "operationId": "Service_SubmitMatchCommand",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serviceSubmitMatchCommandResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ServiceSubmitMatchCommandBody"
            }
          }
        ],
        "tags": [
          "Service"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/v1/namespaces/{namespace}/sessions/{sessionId}/matches/{matchId}/join": {
      "post": {
        "summary": "Join an authoritative Mahjong match",
        "description": "Creates the match from the fixed AGS Session roster when needed and returns the authenticated player's private projection.",
        "operationId": "Service_JoinMatch",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serviceJoinMatchResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "matchId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ServiceJoinMatchBody"
            }
          }
        ],
        "tags": [
          "Service"
        ],
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    }
  },
